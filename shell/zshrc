rerun-last-command() {
  # get last command
  # this will replace current $BUFFER if set
  LBUFFER="$(fc -ln -1)"
  zle && zle redisplay
}

zle -N rerun-last-command
bindkey '^[^[^[' rerun-last-command
bindkey '^[^[^[^[' rerun-last-command
bindkey "^[[1;3C" forward-word
bindkey "^[[1;3D" backward-word

function rebuild() {
  local oldpwd="$PWD"
  cd ~/dotfiles/nix || return
  # cd ~/nix-config || return

  if [[ $(uname) == Darwin ]]; then
    sudo darwin-rebuild switch --flake .#mac "$@" |& nom --json
  else
    echo "not running on darwin, edit zshrc to support"
  fi

  cd "$oldpwd"
}

alias re=rebuild


# curl -sSL https://raw.githubusercontent.com/alacritty/alacritty/master/extra/alacritty.info | tic -x -
h=()
if [[ -r ~/.ssh/config ]]; then
  h=($h ${${${(@M)${(f)"$(cat ~/.ssh/config)"}:#Host *}#Host }:#*[*?]*})
fi
if [[ $#h -gt 0 ]]; then
  zstyle ':completion:*:ssh:*' hosts $h
  zstyle ':completion:*:slogin:*' hosts $h
fi
function gac() {
    git add --all
    git commit -v $@
}
function gacp() {
    git add --all
    git commit -v $@
    git push
}
function find_port_blocker() {
  if ! [ $# -eq 1 ]; then
    cat <<EOF
Please specify the port you want to check
$ find_port_blocker 8000
EOF
    return 1
  fi
  lsof -i -n -P ":$1"
}
function clean_macos_crap() {
  rm -rf {.,_.}{fseventsd,Spotlight-V*,Trashes}
  mkdir .fseventsd
  touch .fseventsd/no_log .metadata_never_index .Trashes
}
# function to call nvim and then exit the shell
function nnvim() {
  nvim "$@"
  exit
}

alias zz="zellij"
alias za="zellij attach"
alias zls="zellij ls"
function zr () { zellij run --name "$*" -- zsh -ic "$*";}
function zrf () { zellij run --name "$*" --floating -- zsh -ic "$*";}
function zri () { zellij run --name "$*" --in-place -- zsh -ic "$*";}
function ze () { zellij edit "$*";}
function zef () { zellij edit --floating "$*";}
function zei () { zellij edit --in-place "$*";}
function zpipe () {
  if [ -z "$1" ]; then
    zellij pipe;
  else
    zellij pipe -p "$1";
  fi
}

_zellij_comp="${XDG_CACHE_HOME:-$HOME/.cache}/zellij_comp.zsh"
if [[ ! -f "$_zellij_comp" ]] || [[ "$(command -v zellij)" -nt "$_zellij_comp" ]]; then
  zellij setup --generate-completion zsh | sed -Ee 's/^(_(zellij) ).*/compdef \1\2/' >| "$_zellij_comp" 2>/dev/null
fi
[[ -f "$_zellij_comp" ]] && . "$_zellij_comp"

[[ "$TERM_PROGRAM" == "vscode" ]] && . "/Applications/Nix Apps/Visual Studio Code.app/Contents/Resources/app/out/vs/workbench/contrib/terminal/common/scripts/shellIntegration-rc.zsh"

